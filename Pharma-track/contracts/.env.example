# ── Deployer Wallet ──────────────────────────────────────────────
PRIVATE_KEY=                    # deployer wallet private key (0x prefixed, 66 chars)

# ── Polygon Mumbai RPC ───────────────────────────────────────────
# Get from: https://dashboard.alchemy.com → Create App → Polygon Mumbai
POLYGON_MUMBAI_RPC=             # e.g. https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY

# ── Contract Verification ────────────────────────────────────────
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# ── Test Wallets (for role assignment during deploy) ─────────────
MANUFACTURER_WALLET=            # 0x... wallet to assign MANUFACTURER_ROLE
DISTRIBUTOR_WALLET=             # 0x... wallet to assign DISTRIBUTOR_ROLE
PHARMACY_WALLET=                # 0x... wallet to assign PHARMACY_ROLE

# ── Database (for seed script only) ──────────────────────────────
# Same DATABASE_URL as backend — used by seed.ts to insert test actors
DATABASE_URL=
