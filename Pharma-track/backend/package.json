{
  "name": "pharmatrack-backend",
  "version": "1.0.0",
  "description": "PharmaTrack — On-Chain Medicine Provenance API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/dotenv": "^6.1.1",
    "@upstash/redis": "^1.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "ethers": "^6.13.1",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.14",
    "postgres": "^3.4.4",
    "qrcode": "^1.5.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.21.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
